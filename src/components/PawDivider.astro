---
const base = import.meta.env.BASE_URL;
const paws = [0, 1, 2, 3, 4];
---
<div class="flex items-center justify-center gap-3 my-8 select-none" aria-hidden="true">
  {paws.map((i) => (
    <img
      src={`${base}ui/paw.png`}
      alt=""
      class="w-5 h-5 pixelated opacity-70 animate-float"
      style={`animation-delay:${i * 0.25}s`}
    />
  ))}
</div>
