---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import CatPanel from "../components/CatPanel.astro";
import PostCard from "../components/PostCard.astro";
import RetroButton from "../components/RetroButton.astro";
import PawDivider from "../components/PawDivider.astro";

const base = import.meta.env.BASE_URL;
const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const postUrl = (slug: string) => `${base}blog/${slug}`;
---
<BaseLayout title="meow.log · a cutesy dev blog" description="Tiny technical notes wrapped in pixel cats.">
  <!-- Hero -->
  <CatPanel class="mb-8">
    <div class="text-center">
      <h1 class="text-xl sm:text-2xl text-cat-cocoa mb-3 leading-relaxed">
        notes from a<br />sleepy little terminal
      </h1>
      <p class="text-cat-ink/80 text-sm max-w-md mx-auto mb-5">
        A little log of my tech journey — the things I build, break, and learn
        along the way.
      </p>
      <div class="flex items-center justify-center gap-3">
        <RetroButton href="#posts" variant="pink">read posts</RetroButton>
        <RetroButton href={`${base}about`} variant="ghost">about</RetroButton>
      </div>
    </div>
  </CatPanel>

  <PawDivider />

  <h2 id="posts" class="text-lg text-cat-cocoa mb-5 flex items-center gap-2">
    <img src={`${base}ui/cat-sit.png`} alt="" class="w-6 pixelated" /> latest posts
  </h2>

  {posts.length === 0 ? (
    <p class="text-cat-cocoa/70">No posts yet — head to <code>/admin</code> to write your first one!</p>
  ) : (
    <div class="grid gap-5 sm:grid-cols-2">
      {posts.map((p) => (
        <PostCard
          url={postUrl(p.slug)}
          title={p.data.title}
          description={p.data.description}
          date={p.data.date}
          tags={p.data.tags}
        />
      ))}
    </div>
  )}
</BaseLayout>
