---
import BaseLayout from "../layouts/BaseLayout.astro";
import Panel from "../components/Panel.astro";
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="about · meow.log">
  <Panel title="about.txt" tone="cream" class="mb-6">
    <div class="flex flex-col sm:flex-row gap-5 items-center sm:items-start">
      <img src={`${base}ui/cat-sit.png`} alt="" class="w-20 pixelated shrink-0" />
      <div class="leading-relaxed">
        <p class="mb-3">
          I'm <strong>Aarshita Acharya</strong>. I graduated with a master's in
          Computer Science from the <strong>University of Houston</strong>.
        </p>
        <p>
          I previously worked at <strong>Goldman Sachs</strong>, and I'm now a
          software developer at <strong>Harris County</strong>. This little
          corner of the web is where I write about my tech journey and the
          things I learn along the way.
        </p>
      </div>
    </div>
  </Panel>
</BaseLayout>
