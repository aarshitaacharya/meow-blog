---
import "../styles/global.css";
import Nav from "../components/Nav.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishDate?: Date;
  jsonLd?: Record<string, any> | Record<string, any>[];
}
const {
  title = "meow.log",
  description = "A cutesy retro dev blog",
  image,
  type = "website",
  publishDate,
  jsonLd,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const sleepers = ["cat-sleep-grey", "cat-sleep-cream", "cat-sleep-white", "cat-sleep-orange"];

// Canonical + OG URL — always the absolute, current page URL
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Fall back to a site-wide default image if a page doesn't supply one
const ogImage = new URL(image ?? `${base}ui/play-sign.png`, Astro.site).href;

// Site-wide schema, always present. Individual pages can pass additional
// schema objects (e.g. BlogPosting) via the jsonLd prop, and we merge them
// into one array so every page ships at least WebSite + Person.
const siteSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "meow.log",
    url: new URL(base, Astro.site).href,
    description: "A cutesy retro dev blog",
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Aarshita Acharya",
    url: new URL(base, Astro.site).href,
  },
];
const fullSchema = jsonLd
  ? [...siteSchema, ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd])]
  : siteSchema;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${base}ui/paw.png`} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>

    <!-- Open Graph (Facebook, LinkedIn, Slack, Discord, iMessage, etc.) -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="meow.log" />
    {type === "article" && publishDate && (
      <meta property="article:published_time" content={publishDate.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(fullSchema)} />
  </head>

  <body class="min-h-screen flex flex-col items-center px-3 py-6 sm:py-10">
    <!-- ── The whole site lives inside one centered pixel panel ── -->
    <div class="w-full max-w-3xl frame !bg-cat-cream p-0 overflow-hidden">
      <!-- window title bar -->
      <div class="titlebar !rounded-none justify-between !m-0 px-4 py-2.5">
        <span class="flex items-center gap-2">
          <span class="flex gap-1" aria-hidden="true">
            <i class="w-2.5 h-2.5 rounded-full bg-cat-rose block"></i>
            <i class="w-2.5 h-2.5 rounded-full bg-cat-butter block"></i>
            <i class="w-2.5 h-2.5 rounded-full bg-cat-blue block"></i>
          </span>
          ~/meow.log
        </span>
        <span class="opacity-70 text-[8px]">v1.0.0</span>
      </div>

      <!-- ── Header: PLAY-sign logo + nav ── -->
      <header class="flex flex-wrap items-center justify-between gap-4 px-5 sm:px-8 pt-6 pb-4">
        <a href={base} class="flex items-center gap-3 group">
          <img
            src={`${base}ui/play-sign.png`}
            alt="meow.log"
            class="h-11 pixelated drop-shadow-[3px_3px_0_#3a2c24] group-hover:animate-wiggle"
          />
          <span class="sr-only">meow.log home</span>
        </a>
        <Nav />
      </header>

      <hr class="border-0 h-1 bg-cat-ink/10 mx-5 sm:mx-8" />

      <!-- ── Page content ── -->
      <main class="px-5 sm:px-8 py-7">
        <slot />
      </main>

      <!-- ── Footer: a pile of sleeping cats ── -->
      <footer class="mt-4 border-t-3 border-cat-ink/10 bg-cat-parchment/60 px-5 sm:px-8 py-5">
        <div class="flex items-end justify-center gap-3 mb-3">
          {sleepers.map((c, i) => (
            <img
              src={`${base}ui/${c}.png`}
              alt=""
              class="h-9 pixelated animate-float"
              style={`animation-delay:${i * 0.4}s`}
            />
          ))}
        </div>
        <p class="text-center text-xs text-cat-cocoa/80">
          made with <span class="text-cat-rose">♥</span> by Aarshita Acharya™
        </p>
      </footer>
    </div>
  </body>
</html>
