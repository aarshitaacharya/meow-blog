---
import BaseLayout from "./BaseLayout.astro";
import PawDivider from "../components/PawDivider.astro";
import PostCard from "../components/PostCard.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  cover?: string;
  relatedPosts?: CollectionEntry<"blog">[];
}
const { title, description, date, tags = [], cover, relatedPosts = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
const human = date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
const postUrl = (slug: string) => `${base}blog/${slug}`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const postSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: description ?? "",
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  url: canonicalURL,
  mainEntityOfPage: canonicalURL,
  keywords: tags.join(", "),
  author: {
    "@type": "Person",
    name: "Aarshita Acharya",
  },
  publisher: {
    "@type": "Person",
    name: "Aarshita Acharya",
  },
};
---
<BaseLayout
  title={`${title} · meow.log`}
  description={description}
  type="article"
  publishDate={date}
  image={cover}
  jsonLd={postSchema}
>
  <a href={base} class="btn btn--ghost text-[9px] py-1.5 px-3 mb-6">← back</a>

  <article>
    <header class="mb-6">
      <h1 class="text-2xl sm:text-3xl text-cat-cocoa leading-relaxed mb-3">{title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-cat-cocoa/80">
        <time class="font-pixel text-[10px]">{human}</time>
        <ul class="flex flex-wrap gap-2">
          {tags.map((t) => (
            <li>
              <a
                href={`${base}tags/${t}`}
                class="font-pixel text-[8px] uppercase bg-cat-parchment border-2 border-cat-ink/30 rounded-pill px-2 py-1 inline-block hover:text-cat-rose"
              >#{t}</a>
            </li>
          ))}
        </ul>
      </div>
      {description && <p class="mt-3 text-cat-ink/80 italic">{description}</p>}
    </header>

    <PawDivider />

    <div class="prose-cat">
      <slot />
    </div>
  </article>

  {relatedPosts.length > 0 && (
    <>
      <PawDivider />
      <h2 class="text-lg text-cat-cocoa mb-5 leading-relaxed">related posts</h2>
      <div class="grid gap-5 sm:grid-cols-2">
        {relatedPosts.map((p) => (
          <PostCard
            url={postUrl(p.slug)}
            title={p.data.title}
            description={p.data.description}
            date={p.data.date}
            tags={p.data.tags}
          />
        ))}
      </div>
    </>
  )}
</BaseLayout>
