---
import BaseLayout from "./BaseLayout.astro";
import PawDivider from "../components/PawDivider.astro";
interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  cover?: string;
}
const { title, description, date, tags = [], cover } = Astro.props;
const base = import.meta.env.BASE_URL;
const human = date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---
<BaseLayout
  title={`${title} · meow.log`}
  description={description}
  type="article"
  publishDate={date}
  image={cover}
>
  <a href={base} class="btn btn--ghost text-[9px] py-1.5 px-3 mb-6">← back</a>

  <article>
    <header class="mb-6">
      <h1 class="text-2xl sm:text-3xl text-cat-cocoa leading-relaxed mb-3">{title}</h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-cat-cocoa/80">
        <time class="font-pixel text-[10px]">{human}</time>
        <ul class="flex flex-wrap gap-2">
          {tags.map((t) => (
            <li class="font-pixel text-[8px] uppercase bg-cat-parchment border-2 border-cat-ink/30 rounded-pill px-2 py-1">#{t}</li>
          ))}
        </ul>
      </div>
      {description && <p class="mt-3 text-cat-ink/80 italic">{description}</p>}
    </header>

    <PawDivider />

    <div class="prose-cat">
      <slot />
    </div>
  </article>
</BaseLayout>
